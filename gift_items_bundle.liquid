    if ($(this).hasClass('unlocked')) {
      return;
    }

    $(this).removeClass('locked').addClass('unlocked');

    if (data_index == 1) {
      $('.grid_wrapper_bd:visible .bundle-box[data_index="2"]').click();
    } else if (data_index == 2) {
      $('.grid_wrapper_bd:visible .bundle-box[data_index="2"]').click();
      $('.gift-item[data_index="1"]').click();
      $('.gift-item[data_index="2"]').click();
    } else if (data_index == 3) {
      $('.grid_wrapper_bd:visible .bundle-box[data_index="3"]').click();
      $('.gift-item').click();
    } else if (data_index == 4) {
      $('.grid_wrapper_bd:visible .bundle-box[data_index="4"]').click();
         $('.gift-item').click();
    }
  });

});
