<style>
.gift-section {
  text-align: center;
  font-family: sans-serif;
}

.gift-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    justify-content: center;
    margin-top: 20px;
    gap: 10px;
}
.gift-item {

  border: 2px solid #cfe3e1;
  border-radius: 16px;
  padding: 6px;
  position: relative;
  cursor: pointer;
  transition: 0.3s;
}
.gift-section h3 {
    text-align: center;
    font-size: 20px;
    font-family: 'DM Sans', sans-serif;
        margin-bottom: 0;
}
.gift-section p {
    margin: 0;
    text-align: center;
    font-size: 16px;
    font-family: 'DM Sans', sans-serif;
}
/* tag */
.tag {
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    background: #d9d9d9;
    padding: 4px 8px;
    font-size: 12px;
    border-radius: 10px;
    display: flex;
    width: 100%;
    text-align: center;
    justify-content: center;
    max-width: 89px;
    color: #000;
}

/* LOCKED STATE */
.gift-item.locked {
  background: #eef3f3;
}

.locked-view {
  display: block;
 
}

.unlocked-view {
  display: none;
}

.lock-icon {
    font-size: 30px;
    display: flex;
    justify-content: center;
    align-items: center;
}
.locked-view p {
    color: #555555;
}


/* UNLOCKED STATE */
.gift-item.unlocked {
  background: #fff;
  border-color: #4e8f88;
}

.gift-item.unlocked .locked-view {
  display: none;
}
.gift-item.unlocked .unlocked-view {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
}
.unlocked-view img {
  width: 90px;
  
  display: block;
}

.unlocked-view p {
  font-size: 13px;
}

@media(max-width:500px){

.gift-wrapper {
    grid-template-columns: 1fr 1fr;
    gap: 25px 10px;
}

}

</style>

















